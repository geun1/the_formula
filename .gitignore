# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.gstack/
.env*.local

# 내부 워크플로우 스크립트 + 레퍼런스 사이트 사본(추적 제외)
/.omc/

# 개발 중간 산출물(계획서·리뷰 메모·조사 노트)
/dev/

# QA 자동화 산출물(Playwright MCP 스냅샷/스크린샷) + env 백업
/.playwright-mcp/
.env.local.qabak
